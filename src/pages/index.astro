---
import Layout from '../layouts/Layout.astro'
import Hero from '../components/sections/Hero.astro'
import About from '../components/sections/About.astro'
import Services from '../components/sections/Services.astro'
import Work from '../components/sections/Work.astro'
import WhyUs from '../components/sections/WhyUs.astro'
import Testimonials from '../components/sections/Testimonials.astro'
import Contact from '../components/sections/Contact.astro'

import { client } from '../lib/sanity'
import { siteSettingsQuery, pageQuery } from '../lib/queries'

const siteSettings = await client.fetch(siteSettingsQuery).catch((e) => {
  console.error('Failed to fetch site settings from Sanity:', e)
  return null
})
const pageData = await client.fetch(pageQuery).catch((e) => {
  console.error('Failed to fetch page data from Sanity:', e)
  return null
})
const pageBuilder = pageData?.pageBuilder || []
---

<Layout title={pageData?.title || 'Walnut Lawn Care - Home'} settings={siteSettings || {}}>
  {
    pageBuilder.length > 0 ? (
      pageBuilder.map((section: any, index: number) => {
        const num = String(index + 1).padStart(2, '0')
        switch (section._type) {
          case 'heroSection':
            return <Hero data={section} settings={siteSettings || {}} />
          case 'aboutSection':
            return <About data={{ ...section, sectionNumber: num }} />
          case 'servicesSection':
            return <Services data={{ ...section, sectionNumber: num }} />
          case 'workSection':
            return <Work data={{ ...section, sectionNumber: num }} />
          case 'whyUsSection':
            return <WhyUs data={{ ...section, sectionNumber: num }} />
          case 'testimonialsSection':
            return <Testimonials data={{ ...section, sectionNumber: num }} />
          case 'contactSection':
            return <Contact data={{ ...section, sectionNumber: num }} />
          default:
            return null
        }
      })
    ) : (
      // Fallback: render sections with hardcoded defaults if no Sanity content yet
      <>
        <Hero data={{}} settings={siteSettings || {}} />
        <About data={{}} />
        <Services data={{}} />
        <Work data={{}} />
        <WhyUs data={{}} />
        <Testimonials data={{}} />
        <Contact data={{}} />
      </>
    )
  }
</Layout>
