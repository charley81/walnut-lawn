---
// Embedded Sanity Studio at https://walnutlawn.net/admin
// Dev: loads Studio from localhost:3333 (run `npx sanity dev --port 3333`)
// Production: loads built Studio from /studio/ (built via `npx sanity build public/studio -y`)
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Walnut Lawn CMS</title>
    <style>
      html, body { margin: 0; padding: 0; height: 100%; }
      iframe { width: 100%; height: 100%; border: none; display: block; }
      #setup {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        font-family: system-ui, sans-serif;
        text-align: center;
        color: #374151;
        padding: 2rem;
      }
      #setup code {
        display: inline-block;
        margin: 0.75rem 0;
        padding: 0.5rem 1rem;
        background: #1f2937;
        color: #10b981;
        border-radius: 6px;
        font-size: 0.9rem;
      }
    </style>
  </head>
  <body>
    <div id="studio">
      <div id="setup">
        <div>
          <h2>Sanity Studio</h2>
          <p>To enable the Studio in production, go to your Sanity dashboard:</p>
          <p style="font-size: 0.9rem; color: #6b7280;">
            <a href="https://www.sanity.io/manage/personal/project/rpjmkqdf/settings" target="_blank">
              sanity.io/manage → Project Settings
            </a><br>
            → Studio → Enable Studio Host
          </p>
          <p style="margin-top: 1rem;">For local dev, run:</p>
          <code>npx sanity dev --port 3333</code>
        </div>
      </div>
    </div>
    <script>
      const isLocal = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1'
      const studioUrl = isLocal
        ? 'http://localhost:3333'
        : '/studio'

      const iframe = document.createElement('iframe')
      iframe.src = studioUrl
      iframe.onload = function() {
        document.getElementById('studio').innerHTML = ''
        document.getElementById('studio').appendChild(iframe)
      }
      document.getElementById('studio').appendChild(iframe)
    </script>
  </body>
</html>
